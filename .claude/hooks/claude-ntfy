#!/usr/bin/env bash
# Send Claude Code hook events to ntfy.
# Reads JSON from stdin (Claude hook payload), extracts message, sends to ntfy.
# Requires NTFY_TOPIC and NTFY_PASSWORD from local.sh.

source "${HOME}/git-repos/personal/dotfiles/config/local.sh" 2>/dev/null

[[ -z "${NTFY_TOPIC}" ]] && exit 0
[[ -z "${NTFY_PASSWORD}" ]] && exit 0

NTFY_SERVER="${NTFY_URL:-https://ntfy.conecrazy.ca}"

# Parse hook payload
payload="$(cat)"
hook_type="$(printf '%s' "${payload}" | python3 -c "import json,sys; d=json.load(sys.stdin); print(d.get('hook_event_name',''))" 2>/dev/null)"
message="$(printf '%s' "${payload}" | python3 -c "import json,sys; d=json.load(sys.stdin); print(d.get('message',''))" 2>/dev/null)"

case "${hook_type}" in
  Notification)
    title="Claude Code"
    body="${message:-Waiting for your input}"
    priority="urgent"
    ;;
  Stop)
    title="Claude Code"
    body="Response complete"
    priority="default"
    ;;
  *)
    title="Claude Code"
    body="${message:-${hook_type}}"
    priority="default"
    ;;
esac

curl -s \
  -u "${NTFY_USER}:${NTFY_PASSWORD}" \
  -H "Title: ${title}" \
  -H "Priority: ${priority}" \
  -H "Tags: robot" \
  -d "${body}" \
  "${NTFY_SERVER}/${NTFY_TOPIC}" \
  > /dev/null 2>&1 || true
