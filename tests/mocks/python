#!/usr/bin/env bash
printf "python %s\n" "$*" >> "${MOCK_CALLS_FILE:-/tmp/mock_calls}"
# For 'python -m pip list --outdated --format=json', output empty JSON array
if [[ "$*" == *"pip list"*"--outdated"* ]]; then
  printf "[]\n"
  exit 0
fi
# For 'python -m pip install', just succeed
if [[ "$*" == *"pip install"* ]]; then
  exit "${MOCK_PYTHON_PIP_INSTALL_EXIT:-0}"
fi
# For 'python -m pip check', just succeed
if [[ "$*" == *"pip check"* ]]; then
  exit 0
fi
# For 'python -' (heredoc execution): simulate the pip update Python script.
# Consumes stdin (the Python source), then writes pip_outdated to _UPDATE_TMPDIR.
# Set MOCK_PYTHON_HEREDOC_PKGS to simulate outdated packages (newline-separated).
if [[ "$1" == "-" ]]; then
  cat >/dev/null
  printf "%s" "${MOCK_PYTHON_HEREDOC_PKGS:-}" > "${_UPDATE_TMPDIR:-/tmp}/pip_outdated"
  exit 0
fi
exit "${MOCK_PYTHON_EXIT:-0}"
