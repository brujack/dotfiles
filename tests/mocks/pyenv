#!/usr/bin/env bash
printf "pyenv %s\n" "$*" >> "${MOCK_CALLS_FILE:-/tmp/mock_calls}"
# For 'pyenv init -' and 'pyenv virtualenv-init -', output nothing (no-op eval)
if [[ "$1" == "init" ]] || [[ "$1" == "virtualenv-init" ]]; then
  printf ""
  exit 0
fi
# For 'pyenv which python', output MOCK_PYENV_WHICH_STDOUT or real python3 path
if [[ "$1" == "which" ]]; then
  if [[ -n "${MOCK_PYENV_WHICH_STDOUT:-}" ]]; then
    printf "%s\n" "${MOCK_PYENV_WHICH_STDOUT}"
  else
    command -v python3 || printf "/usr/bin/python3\n"
  fi
  exit 0
fi
# Allow per-subcommand exit code override for virtualenv-delete
if [[ "$1" == "virtualenv-delete" ]]; then
  exit "${MOCK_PYENV_VIRTUALENV_DELETE_EXIT:-${MOCK_PYENV_EXIT:-0}}"
fi
exit "${MOCK_PYENV_EXIT:-0}"
